{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-api-url.onrender.com/api/:path*"
    },
    {
      "source": "/models/:path*",
      "destination": "https://your-backend-api-url.onrender.com/models/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
